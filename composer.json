{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "barryvdh/laravel-dompdf": "^3.1",
        "bensampo/laravel-enum": "^6.6",
        "codedge/laravel-fpdf": "^1.12",
        "doctrine/dbal": "^3.0",
        "guzzlehttp/guzzle": "^7.2",
        "hisorange/browser-detect": "^4.3",
        "kmlaravel/laravel-geographical-calculator": "^1.1",
        "laravel/fortify": "^1.16",
        "laravel/framework": "^10.9.0",
        "laravel/reverb": "^1.7",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.8",
        "livewire/livewire": "^3.0",
        "maatwebsite/excel": "^3.1",
        "predis/predis": "^3.3",
        "pusher/pusher-php-server": "^7.2",
        "react/event-loop": "^1.6",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-medialibrary": "^10.15",
        "spatie/laravel-permission": "^5.10",
        "spatie/laravel-query-builder": "^5.2",
        "torann/geoip": "^3.0",
        "uro/teltonika-fm-parser": "^3.0",
        "yajra/laravel-datatables-oracle": "^10.8",
        "yajra/laravel-oci8": "10"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "fakerphp/faker": "^1.9.1",
        "knuckleswtf/scribe": "^4.17",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.25",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpro/grumphp-shim": "^1.15",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpro/grumphp-shim": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
